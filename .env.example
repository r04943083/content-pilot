# AI Provider: "qwen", "glm", "openai", or "claude"
CP_AI__PROVIDER=qwen

# AI Provider API Keys (set the one matching your provider)
CP_AI__QWEN_API_KEY=sk-...
CP_AI__GLM_API_KEY=...
CP_AI__ANTHROPIC_API_KEY=sk-ant-...
CP_AI__OPENAI_API_KEY=sk-...

# Database path (default: data/content_pilot.db)
# CP_DATABASE__PATH=data/content_pilot.db

# Timezone (default: Asia/Shanghai)
# CP_GENERAL__TIMEZONE=Asia/Shanghai

# Safety: require human review before publishing (default: true)
# CP_SAFETY__REQUIRE_REVIEW=true

# Rate limiting: max posts per platform per day (default: 3)
# CP_SAFETY__MAX_POSTS_PER_DAY=3
